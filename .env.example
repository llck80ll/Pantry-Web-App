# Environment Variables Example for My Pantry Recipes

# Required for Gemini AI API calls. AI Studio automatically injects this at runtime from secrets.
GEMINI_API_KEY=

# The URL where this applet is hosted. AI Studio injects this at runtime.
APP_URL=

# Required for Supabase Auth and per-user saved pantry/starred recipes.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
